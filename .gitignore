# ai-hacklab-starter .gitignore

# ── Secrets & generated configs (never commit these) ─────────────────────────
.env
dispatch/key_pools.json
dispatch/agent_registry.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.whl
.venv/
venv/
env/
pip-wheel-metadata/

# ── Databases & research artifacts ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backups/

# ── Docker ───────────────────────────────────────────────────────────────────
*.log

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

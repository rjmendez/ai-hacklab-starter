# A2A Server
AGENT_NAME=alpha
AGENT_TOKEN=<generate: python -c "import secrets; print(secrets.token_hex(32))">
AGENT_TOTP_SEED=<generate: python totp/generate_seed.py>
AGENT_URL=http://YOUR_AGENT_IP:8200

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<set a strong password>

# LiteLLM proxy
LITELLM_BASE_URL=http://litellm-proxy:4000/v1
LITELLM_API_KEY=<your litellm master key>

# LLM providers (add whichever you use)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Peer agent tokens (to call other agents in the mesh)
AGENT_ALPHA_TOKEN=
AGENT_BETA_TOKEN=
AGENT_GAMMA_TOKEN=
AGENT_DELTA_TOKEN=

# Databases (optional)
MEMORY_DB_DSN=postgresql://user:pass@localhost:5432/agent_memory
AUDIT_DB_DSN=postgresql://user:pass@localhost:5432/audit_db